# resource_id: "2bbf3c16-9b29-4165-89f7-0d5ae91ab74f"
# resource_type: "document"
# resource_name: ".env"
# ===========================================
# API Keys for Claude Code CLI (Linux/Cursor)
# ===========================================
# DO NOT COMMIT actual values - copy this to .env and fill in
# Get actual values from: ~/.env or Google Secret Manager
# ===========================================

# Canvas LMS API (BYU-Idaho)
CANVAS_API_KEY=your_canvas_api_key_here
CANVAS_BASE_URL=https://byui.instructure.com

# Perplexity API
PERPLEXITY_API_KEY=pplx-your_perplexity_api_key_here

# ===========================================
# Quick Setup
# ===========================================
# Option 1: Copy from home directory
#   cp ~/.env .env
#
# Option 2: Symlink (recommended)
#   ln -sf ~/.env .env
#
# Option 3: Retrieve from Secret Manager
#   CANVAS_API_KEY=$(gcloud secrets versions access latest --secret=CANVAS_API_KEY)
#   PERPLEXITY_API_KEY=$(gcloud secrets versions access latest --secret=PERPLEXITY_API_KEY)

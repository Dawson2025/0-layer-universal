# MCP Servers Secrets - DO NOT TRACK THESE FILES

# Local configuration files with actual API keys
*.local.json
config.local.*

# Secrets directory
.secrets/

# Environment/secrets files
*.secrets.sh
.env
.env.local
.env.*.local

# Backup files that might contain secrets
*.bak
*.backup
*~

# OS-generated files that might cache secrets
.DS_Store
Thumbs.db

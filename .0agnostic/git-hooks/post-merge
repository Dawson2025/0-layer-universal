#!/usr/bin/env bash
# resource_id: "b2e1c4a3-7f89-4d56-a1e3-9c8b2d4f6a71"
# resource_type: "script"
# resource_name: "post-merge-hook"
#
# Git post-merge hook: rebuild UUID index and validate pointers after pull/merge.
# Install: ln -sf ../../.0agnostic/git-hooks/post-merge .git/hooks/post-merge

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"

# Source resolve-uuid for UUID-based script discovery
source "$REPO_ROOT/.0agnostic/03_protocols/pointer_sync_protocol/tools/resolve-uuid.sh"
POINTER_SYNC="$(resolve-uuid 08a4e9bc-8cc1-457e-b966-0a912ae6dff7 2>/dev/null || echo "$REPO_ROOT/.0agnostic/03_protocols/pointer_sync_protocol/tools/pointer-sync.sh")"

# Always rebuild UUID index after merge (ensures resolve-uuid works for subsequent calls)
echo "[post-merge] Rebuilding UUID index..."
bash "$POINTER_SYNC" --rebuild-index

# Rebuild directory UUID index if any .dir-id files changed
if git diff-tree -r --name-only ORIG_HEAD HEAD | grep -q '\.dir-id$'; then
    echo "[post-merge] .dir-id files changed — rebuilding directory UUID index..."
    bash "$POINTER_SYNC" --rebuild-dir-index
fi

# Validate pointers
echo "[post-merge] Validating pointers..."
bash "$POINTER_SYNC" --validate || {
    echo "[post-merge] WARNING: Broken pointers detected after merge. Run: pointer-sync.sh"
}

#!/usr/bin/env bash
# resource_id: "a1b2c3d4-e5f6-4a7b-8c9d-0e1f2a3b4c5e"
# resource_type: "script"
# resource_name: "post-checkout-hook"
#
# Git post-checkout hook: rebuild UUID index after branch switches.
# Ensures resolve-uuid always returns current paths.
# Install: ln -sf ../../.0agnostic/git-hooks/post-checkout .git/hooks/post-checkout

set -euo pipefail

# Only run on branch checkouts (flag=1), not file checkouts (flag=0)
FLAG="${3:-0}"
if [[ "$FLAG" != "1" ]]; then
    exit 0
fi

REPO_ROOT="$(git rev-parse --show-toplevel)"

# Source resolve-uuid for UUID-based script discovery
source "$REPO_ROOT/.0agnostic/03_protocols/pointer_sync_protocol/tools/resolve-uuid.sh"
POINTER_SYNC="$(resolve-uuid 08a4e9bc-8cc1-457e-b966-0a912ae6dff7 2>/dev/null || echo "$REPO_ROOT/.0agnostic/03_protocols/pointer_sync_protocol/tools/pointer-sync.sh")"

echo "[post-checkout] Rebuilding UUID index..."
bash "$POINTER_SYNC" --rebuild-index --quiet

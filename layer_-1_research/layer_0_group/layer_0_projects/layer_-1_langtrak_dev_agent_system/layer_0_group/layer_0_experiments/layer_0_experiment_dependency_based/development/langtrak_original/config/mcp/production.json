{
  "environment": "production",
  "servers": [
    {
      "name": "web-search",
      "command": "npx",
      "args": ["tavily-mcp"],
      "env": {
        "TAVILY_API_KEY": "tvly-prod-REPLACE_WITH_PRODUCTION_KEY"
      },
      "enabled": true,
      "priority": 1,
      "category": "search",
      "description": "Tavily web search MCP server",
      "dependencies": ["node"],
      "health_check_url": null,
      "timeout": 30,
      "retry_count": 3
    },
    {
      "name": "github-search",
      "command": "npx",
      "args": ["github-mcp-server"],
      "env": {
        "GITHUB_TOKEN": "ghp_REPLACE_WITH_PRODUCTION_TOKEN"
      },
      "enabled": true,
      "priority": 2,
      "category": "search",
      "description": "GitHub search MCP server",
      "dependencies": ["node"],
      "health_check_url": null,
      "timeout": 30,
      "retry_count": 3
    },
    {
      "name": "filesystem",
      "command": "npx",
      "args": ["@modelcontextprotocol/server-filesystem", "/home/dawson/code/lang-trak-in-progress"],
      "env": {},
      "enabled": true,
      "priority": 1,
      "category": "filesystem",
      "description": "Filesystem access MCP server",
      "dependencies": ["node"],
      "health_check_url": null,
      "timeout": 30,
      "retry_count": 3
    },
    {
      "name": "slack",
      "command": "npx",
      "args": ["@modelcontextprotocol/server-slack"],
      "env": {
        "SLACK_BOT_TOKEN": "xoxb-REPLACE_WITH_PRODUCTION_TOKEN"
      },
      "enabled": true,
      "priority": 3,
      "category": "communication",
      "description": "Slack integration MCP server",
      "dependencies": ["node"],
      "health_check_url": null,
      "timeout": 30,
      "retry_count": 3
    },
    {
      "name": "postgres",
      "command": "npx",
      "args": ["@modelcontextprotocol/server-postgres"],
      "env": {
        "POSTGRES_CONNECTION_STRING": "postgresql://user:password@localhost:5432/firebase_config"
      },
      "enabled": true,
      "priority": 2,
      "category": "database",
      "description": "PostgreSQL MCP server",
      "dependencies": ["node", "postgresql"],
      "health_check_url": null,
      "timeout": 30,
      "retry_count": 3
    },
    {
      "name": "context7-local",
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp", "--api-key", "ctx7sk-d20b6dec-5980-4ee1-9beb-0e635d626f46"],
      "env": {},
      "enabled": true,
      "priority": 3,
      "category": "documentation",
      "description": "Context7 local MCP server with API access",
      "dependencies": ["node"],
      "health_check_url": null,
      "timeout": 30,
      "retry_count": 3
    },
    {
      "name": "context7-remote",
      "command": "curl",
      "args": ["-X", "POST", "https://mcp.context7.com/mcp"],
      "env": {},
      "enabled": false,
      "priority": 4,
      "category": "documentation",
      "description": "Context7 remote MCP server (HTTP-based)",
      "dependencies": ["curl"],
      "health_check_url": "https://mcp.context7.com/mcp",
      "timeout": 30,
      "retry_count": 3,
      "mcp_type": "remote",
      "mcp_url": "https://mcp.context7.com/mcp",
      "mcp_headers": {
        "CONTEXT7_API_KEY": "ctx7sk-d20b6dec-5980-4ee1-9beb-0e635d626f46"
      }
    }
  ],
  "global_env": {
    "NODE_ENV": "production",
    "LOG_LEVEL": "info"
  },
  "timeout": 60,
  "max_concurrent_servers": 5
}

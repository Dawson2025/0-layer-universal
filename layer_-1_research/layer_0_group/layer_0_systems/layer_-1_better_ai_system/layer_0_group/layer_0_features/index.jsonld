{
  "@context": {
    "@vocab": "https://layer-stage.dev/schema#",
    "nav": "https://layer-stage.dev/nav#",
    "rel": "https://layer-stage.dev/rel#",
    "trigger": "https://layer-stage.dev/trigger#"
  },

  "@id": "layer_0_features",
  "@type": "FeaturesRegistry",
  "layer": 0,

  "name": "Layer 0 Features",
  "description": "Research features for the better_ai_system project",

  "nav:parent": {
    "@id": "../",
    "name": "layer_0_group"
  },

  "conventions": {
    "childNaming": {
      "pattern": "layer_{N}_{type}_{name}",
      "currentLayer": 0,
      "example": "layer_0_feature_layer_stage_system",
      "note": "Features are at same layer as registry; sub_features inside are layer+1"
    }
  },

  "trigger:onEntityCreation": {
    "skill": "../.claude/skills/entity-creation/",
    "loads": ["conventions.childNaming"],
    "reference": ".0agnostic/06_context_avenue_web/01_file_based/04_@import_references/entity_structure.md"
  },

  "features": [
    {
      "@id": "layer_0_feature_layer_stage_system/",
      "@type": "Feature",
      "name": "Layer-Stage System",
      "description": "Central pillar: the layer-stage framework itself — memory/context chains, organization/entities, multi-agent orchestration, and tool-agnostic systems",
      "note": "Phase 3: restructured from agent_performance into 3-pillar architecture",
      "rel:treeOfNeedsBranch": ["01_capable", "02_continuous", "03_trustworthy", "04_observable", "06_context_flow"],
      "children": [
        "layer_1_sub_feature_memory_system",
        "layer_1_sub_feature_organization",
        "layer_1_sub_feature_multi_agent_system",
        "layer_1_sub_feature_tool_and_app_agnostic"
      ]
    },
    {
      "@id": "layer_0_feature_multi_os_multi_machine_system/",
      "@type": "Feature",
      "name": "Multi-OS Multi-Machine System",
      "description": "Cross-platform setup, configuration, and synchronization across operating systems and machines",
      "note": "Phase 3: extracted from agent_performance/organization/setup OS-specific content",
      "rel:treeOfNeedsBranch": ["02_continuous", "04_observable"],
      "children": []
    },
    {
      "@id": "layer_0_feature_multimodal_system/",
      "@type": "Feature",
      "name": "Multimodal System",
      "description": "Future multimodal capabilities — video, audio, TTS/STT, 3D, and other non-text modalities",
      "note": "Phase 3: empty skeleton for future research",
      "rel:treeOfNeedsBranch": ["01_capable"],
      "children": []
    }
  ]
}

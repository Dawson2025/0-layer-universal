{
  "@context": {
    "@vocab": "https://layer-stage.dev/schema#",
    "nav": "https://layer-stage.dev/nav#",
    "trigger": "https://layer-stage.dev/trigger#"
  },

  "@id": "layer_0_99_stages",
  "@type": "StagesFolder",

  "name": "Layer 0 Stages",
  "description": "The 11 development stages for universal content",
  "layer": 0,

  "nav:parent": {
    "@id": "../",
    "name": "layer_0_group"
  },

  "stages": [
    {
      "@id": "stage_0_00_stage_registry/",
      "stage": 0,
      "name": "Stage Registry",
      "description": "Metadata and registration for all stages",
      "trigger:skill": "../../.claude/skills/00_stage_manager-workflow/"
    },
    {
      "@id": "stage_0_01_request_gathering/",
      "stage": 1,
      "name": "Request Gathering",
      "description": "Collect requirements, create tree of needs",
      "trigger:skill": "../../.claude/skills/01_request_gathering-workflow/",
      "hasTreeOfNeeds": true
    },
    {
      "@id": "stage_0_02_research/",
      "stage": 2,
      "name": "Research",
      "description": "Explore problem space, gather information",
      "trigger:skill": "../../.claude/skills/02_research-workflow/"
    },
    {
      "@id": "stage_0_03_instructions/",
      "stage": 3,
      "name": "Instructions",
      "description": "Document constraints, setup, usage",
      "trigger:skill": "../../.claude/skills/03_instructions-workflow/"
    },
    {
      "@id": "stage_0_04_planning/",
      "stage": 4,
      "name": "Planning",
      "description": "Break work into tasks, create roadmap"
    },
    {
      "@id": "stage_0_05_design/",
      "stage": 5,
      "name": "Design",
      "description": "Architecture, proposals, system design"
    },
    {
      "@id": "stage_0_06_development/",
      "stage": 6,
      "name": "Development",
      "description": "Implementation, coding, building"
    },
    {
      "@id": "stage_0_07_testing/",
      "stage": 7,
      "name": "Testing",
      "description": "Verification, validation, QA"
    },
    {
      "@id": "stage_0_08_criticism/",
      "stage": 8,
      "name": "Criticism",
      "description": "Review, analysis, feedback"
    },
    {
      "@id": "stage_0_09_fixing/",
      "stage": 9,
      "name": "Fixing",
      "description": "Corrections, improvements, iterations"
    },
    {
      "@id": "stage_0_10_current_product/",
      "stage": 10,
      "name": "Current Product",
      "description": "Final deliverable, production state"
    },
    {
      "@id": "stage_0_11_archives/",
      "stage": 11,
      "name": "Archives",
      "description": "Historical records, past versions"
    }
  ],

  "trigger:onStageEntry": {
    "action": "loadSkill",
    "pattern": "stages[?].trigger:skill"
  }
}

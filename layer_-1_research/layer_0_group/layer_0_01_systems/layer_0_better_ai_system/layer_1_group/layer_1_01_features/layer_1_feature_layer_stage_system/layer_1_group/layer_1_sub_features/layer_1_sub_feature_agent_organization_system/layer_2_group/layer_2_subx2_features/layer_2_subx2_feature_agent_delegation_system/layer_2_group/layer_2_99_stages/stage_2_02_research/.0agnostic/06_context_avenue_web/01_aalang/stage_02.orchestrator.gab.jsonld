      "includes": [
        "Investigation methodology",
        "Collected data and evidence",
        "Pattern analysis results",
        "Coverage tracking"
      ],
      "readableBy": [
        "rs:ExecutePersona1",
        "rs:ExecutePersona2"
      ],
      "unreadableBy": [

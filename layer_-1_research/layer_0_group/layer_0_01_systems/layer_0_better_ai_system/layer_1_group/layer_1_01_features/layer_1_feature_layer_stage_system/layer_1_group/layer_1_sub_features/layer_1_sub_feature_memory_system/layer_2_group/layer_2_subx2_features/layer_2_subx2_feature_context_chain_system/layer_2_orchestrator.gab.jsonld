      "role": "StateManager",
      "sessionConsistent": true,
      "purpose": "Track active research tasks and their progress"
    },
    {
      "@id": "orch:TaskStatePersona",
      "@type": "gab:Persona",
      "name": "Task State Manager",
      "role": "StateManager",
      "personality": "Organized, tracks progress",
      "responsibilities": [
        "Track research tasks",
        "Maintain task decomposition",
        "Update progress metrics"
      ],
      "mode": null,
      "actor": "orch:TaskStateActor",
      "canMessage": [],
      "canReceiveFrom": [],
      "sessionConsistent": true
    },
    {
      "@id": "orch:ReceiveMode",
      "@type": "gab:Mode",
      "purpose": "Parse incoming context chain research tasks, validate scope, classify research type",
      "constraints": [
        "Check hand_off_documents/incoming/ for tasks",
        "Validate task is within context chain research scope",
        "Classify research type (chain construction, optimization, visualization)",
        "Do NOT proceed to ResearchMode until task is fully parsed"
      ],
      "contains": [
        "orch:ReceivePersona1",
        "orch:ReceivePersona2"
      ],
      "isolatedState": "orch:ReceiveModeState",
      "initialMode": true,
      "precedes": [
        "orch:ResearchMode"
      ]
    },
    {
      "@id": "orch:ResearchMode",
      "@type": "gab:Mode",
      "purpose": "Investigate context chain patterns, gather data on how context flows through hierarchies",
      "constraints": [
        "Use research tools (Perplexity, WebSearch) for external data",
        "Review existing context chain implementations and diagrams",
        "Analyze static/dynamic and fixed/configurable dimensions",
        "Document findings in stage_02_research outputs",
        "Do NOT proceed to DesignMode until research is comprehensive"
      ],
      "contains": [
        "orch:ResearchPersona1",
        "orch:ResearchPersona2"
      ],
      "isolatedState": "orch:ResearchModeState",
      "precedes": [
        "orch:DesignMode"
      ]
    },
    {
      "@id": "orch:DesignMode",
      "@type": "gab:Mode",
      "purpose": "Design context chain architecture improvements, create specifications for chain optimization",
      "constraints": [
        "Build on research findings from ResearchMode",
        "Create specifications with clear acceptance criteria",
        "Design must respect static/dynamic and fixed/configurable dimensions",
        "Document designs in stage_04_design outputs",
        "Do NOT proceed to ImplementMode until design is reviewed"
      ],
      "contains": [
        "orch:DesignPersona1",
        "orch:DesignPersona2"
      ],
      "isolatedState": "orch:DesignModeState",
      "precedes": [
        "orch:ImplementMode"
      ]
    },
    {
      "@id": "orch:ImplementMode",
      "@type": "gab:Mode",
      "purpose": "Execute the design, create context chain artifacts and research content",
      "constraints": [
        "Follow the approved design specification",
        "Create artifacts in appropriate stage directories",
        "Write content that follows context chain conventions",
        "Do NOT modify production context chain systems directly",
        "Do NOT proceed to ReviewMode until implementation is complete"
      ],
      "contains": [
        "orch:ImplementPersona1",
        "orch:ImplementPersona2"
      ],
      "isolatedState": "orch:ImplementModeState",
      "precedes": [
        "orch:ReviewMode"
      ]
    },
    {
      "@id": "orch:ReviewMode",
      "@type": "gab:Mode",
      "purpose": "Validate context chain research output, ensure quality, prepare for delivery",
      "constraints": [
        "Validate all artifacts against design specifications",
        "Ensure research sources are cited",
        "Check context chain architecture compliance",
        "Write results to hand_off_documents/outgoing/",
        "Transition back to ReceiveMode after delivery"
      ],
      "contains": [
        "orch:ReviewPersona1",
        "orch:ReviewPersona2"
      ],
      "isolatedState": "orch:ReviewModeState",
      "precedes": [
        "orch:ReceiveMode"
      ]
    },
    {

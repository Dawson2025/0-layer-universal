    {
      "@id": "ads:ReceiveMode",
      "@type": "gab:Mode",
      "purpose": "Parse incoming delegation tasks, validate scope, classify work type",
      "constraints": [
        "Check .0agnostic/09_handoff_documents/ for incoming tasks",
        "Validate task is within agent delegation scope",
        "Classify work type (stage delegation, cross-stage, child feature)",
        "Read stage reports to understand current state",
        "Do NOT proceed to ResearchMode until task is fully parsed"
      ],
      "contains": [
        "ads:ReceivePersona1",
        "ads:ReceivePersona2"
      ],
      "isolatedState": "ads:ReceiveModeState",
      "initialMode": true,
      "precedes": [
        "ads:ResearchMode"
      ]
    },
    {
      "@id": "ads:ResearchMode",
      "@type": "gab:Mode",
      "purpose": "Investigate delegation patterns, analyze current implementations, gather data",
      "constraints": [
        "Review existing stage outputs and stage reports",
        "Analyze delegation patterns across the hierarchy",
        "Use research tools for external data on multi-agent patterns",
        "Document findings in stage_02_research outputs",
        "Do NOT proceed to DesignMode until research is comprehensive"
      ],
      "contains": [
        "ads:ResearchPersona1",
        "ads:ResearchPersona2"
      ],
      "isolatedState": "ads:ResearchModeState",
      "precedes": [
        "ads:DesignMode"
      ]
    },
    {
      "@id": "ads:DesignMode",
      "@type": "gab:Mode",
      "purpose": "Design delegation architectures, stage agent patterns, context models",
      "constraints": [
        "Build on research findings from ResearchMode",
        "Create specifications with clear acceptance criteria",
        "Design must respect layer-stage hierarchy",
        "Document designs in stage_04_design outputs",
        "Do NOT proceed to ImplementMode until design is reviewed"
      ],
      "contains": [
        "ads:DesignPersona1",
        "ads:DesignPersona2"
      ],
      "isolatedState": "ads:DesignModeState",
      "precedes": [
        "ads:ImplementMode"
      ]
    },
    {
      "@id": "ads:ImplementMode",
      "@type": "gab:Mode",
      "purpose": "Build delegation artifacts — stage guides, templates, rules, protocols",
      "constraints": [
        "Follow the approved design specification",
        "Create artifacts in appropriate stage or .0agnostic/ directories",
        "Follow layer-stage conventions for all artifacts",
        "Do NOT modify parent or sibling entity systems directly",
        "Do NOT proceed to ReviewMode until implementation is complete"
      ],
      "contains": [
        "ads:ImplementPersona1",
        "ads:ImplementPersona2"
      ],
      "isolatedState": "ads:ImplementModeState",
      "precedes": [
        "ads:ReviewMode"
      ]
    },
    {
      "@id": "ads:ReviewMode",
      "@type": "gab:Mode",
      "purpose": "Validate delegation artifacts, ensure quality, prepare handoffs",
      "constraints": [
        "Validate all artifacts against design specifications",
        "Ensure delegation model is testable",
        "Check layer-stage hierarchy compliance",
        "Write results to .0agnostic/09_handoff_documents/outgoing/",
        "Transition back to ReceiveMode after delivery"
      ],
      "contains": [
        "ads:ReviewPersona1",
        "ads:ReviewPersona2"
      ],
      "isolatedState": "ads:ReviewModeState",
      "precedes": [
        "ads:ReceiveMode"
      ]
    },

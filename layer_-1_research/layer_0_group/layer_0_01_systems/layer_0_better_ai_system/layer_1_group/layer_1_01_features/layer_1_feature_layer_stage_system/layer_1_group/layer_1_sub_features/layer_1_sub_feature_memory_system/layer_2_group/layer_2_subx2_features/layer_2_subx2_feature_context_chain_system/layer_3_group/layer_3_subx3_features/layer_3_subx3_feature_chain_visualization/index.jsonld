{
  "@context": {
    "@vocab": "https://layer-stage.dev/schema#",
    "nav": "https://layer-stage.dev/nav#",
    "rel": "https://layer-stage.dev/rel#",
    "trigger": "https://layer-stage.dev/trigger#"
  },

  "@id": "layer_1_subx2_feature_context_visualization",
  "@type": "SubFeature",
  "layer": 1,

  "name": "Context Visualization",
  "description": "Diagrams and tools for visualizing context flow, architecture, and propagation",

  "nav:parent": {
    "@id": "../",
    "name": "layer_0_feature_context_framework"
  },

  "nav:siblings": [
    {"@id": "../layer_1_subx2_feature_context_system/", "name": "Context System"},
    {"@id": "../layer_1_subx2_feature_dynamic_memory/", "name": "Dynamic Memory"},
    {"@id": "../layer_1_subx2_feature_navigation_system/", "name": "Navigation System"}
  ],

  "conventions": {
    "childNaming": {
      "pattern": "layer_{N+1}_{type}_{name}",
      "currentLayer": 1,
      "childLayer": 2,
      "example": "layer_2_component_diagram_renderer"
    }
  },

  "trigger:onEntityCreation": {
    "skill": "../../.claude/skills/entity-creation/",
    "loads": ["conventions.childNaming"]
  },

  "rel:treeOfNeedsBranch": {
    "branch": "06_context_flow",
    "primaryNeeds": [
      "need_02_context_propagation_works",
      "need_05_entry_points_right_detail",
      "need_06_navigation_to_deeper_details"
    ]
  },

  "nav:children": [
    {
      "@id": "diagrams/",
      "name": "Diagrams",
      "description": "Context visualization diagrams",
      "children": [
        {"@id": "diagrams/current/", "name": "Current State Diagrams"},
        {"@id": "diagrams/proposed/", "name": "Proposed State Diagrams"}
      ]
    },
    {
      "@id": "tools/",
      "name": "Tools",
      "description": "Diagram generation and comparison tools"
    }
  ],

  "diagramTypes": {
    "contextArchitecture": {
      "purpose": "What context exists and where it lives",
      "answers": "What context is available?",
      "location": "diagrams/current/context_architecture.md"
    },
    "contextFlow": {
      "purpose": "When context loads and in what order",
      "answers": "When does context load?",
      "location": "diagrams/current/context_flow.md"
    },
    "contextPropagation": {
      "purpose": "How context moves through hierarchy",
      "answers": "How does context propagate?",
      "location": "diagrams/current/context_propagation.md"
    },
    "beforeAfter": {
      "purpose": "Impact of proposed changes",
      "answers": "What will change?",
      "location": "diagrams/proposed/{proposal_name}/"
    }
  }
}

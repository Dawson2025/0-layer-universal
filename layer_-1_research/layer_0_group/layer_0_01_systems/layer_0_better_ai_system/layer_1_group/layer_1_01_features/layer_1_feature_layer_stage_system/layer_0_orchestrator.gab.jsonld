    },
    {
      "@id": "orch:ChildRegistryStatePersona",
      "@type": "gab:Persona",
      "name": "Child Registry Manager",
      "role": "StateManager",
      "personality": "Meticulous, accurate",
      "responsibilities": [
        "Register child sub-features",
        "Track sub-feature status",
        "Detect orphaned entities"
      ],
      "mode": null,
      "actor": "orch:ChildRegistryStateActor",
      "canMessage": [],
      "canReceiveFrom": [],
      "sessionConsistent": true
    },
    {
      "@id": "orch:TaskStateActor",
      "@type": "gab:Actor",
      "id": "TaskStateActor",
      "operatesIn": [
        "orch:ReceiveMode",
        "orch:ResearchMode",
        "orch:DesignMode",
        "orch:ImplementMode",
        "orch:ReviewMode"
      ],
      "activeMode": null,
      "persona": "orch:TaskStatePersona",
      "role": "StateManager",
      "sessionConsistent": true,
      "purpose": "Track active research tasks and their progress"
    },
    {
      "@id": "orch:TaskStatePersona",
      "@type": "gab:Persona",
      "name": "Task State Manager",
      "role": "StateManager",
      "personality": "Organized, tracks progress",
      "responsibilities": [
        "Track research tasks",
        "Maintain task decomposition",
        "Update progress metrics"
      ],
      "mode": null,
      "actor": "orch:TaskStateActor",
      "canMessage": [],
      "canReceiveFrom": [],
      "sessionConsistent": true
    },
    {
      "@id": "orch:ReceiveMode",
      "@type": "gab:Mode",
      "purpose": "Parse incoming research tasks, validate scope, classify research type",
      "constraints": [
        "Check hand_off_documents/incoming/ for tasks",
        "Validate task is within layer-stage research scope",
        "Classify research type (exploration, design, implementation)",
        "Do NOT proceed to ResearchMode until task is fully parsed"
      ],
      "contains": [
        "orch:ReceivePersona1",
        "orch:ReceivePersona2"
      ],
      "isolatedState": "orch:ReceiveModeState",
      "initialMode": true,
      "precedes": [
        "orch:ResearchMode"
      ]
    },
    {
      "@id": "orch:ResearchMode",
      "@type": "gab:Mode",
      "purpose": "Investigate existing work, gather data, analyze patterns in layer-stage architecture",
      "constraints": [
        "Use research tools (Perplexity, WebSearch) for external data",
        "Review existing layer-stage documentation and designs",
        "Analyze patterns across current implementations",
        "Document findings in stage_02_research outputs",
        "Do NOT proceed to DesignMode until research is comprehensive"
      ],
      "contains": [
        "orch:ResearchPersona1",
        "orch:ResearchPersona2"
      ],
      "isolatedState": "orch:ResearchModeState",
      "precedes": [
        "orch:DesignMode"
      ]
    },
    {
      "@id": "orch:DesignMode",
      "@type": "gab:Mode",
      "purpose": "Design solutions, create specifications, plan implementation for layer-stage improvements",
      "constraints": [
        "Build on research findings from ResearchMode",
        "Create specifications with clear acceptance criteria",
        "Design must respect layer-stage hierarchy constraints",
        "Document designs in stage_04_design outputs",
        "Do NOT proceed to ImplementMode until design is reviewed"
      ],
      "contains": [
        "orch:DesignPersona1",
        "orch:DesignPersona2"
      ],
      "isolatedState": "orch:DesignModeState",
      "precedes": [
        "orch:ImplementMode"
      ]
    },
    {
      "@id": "orch:ImplementMode",
      "@type": "gab:Mode",
      "purpose": "Execute the design, create artifacts, write research content for layer-stage framework",
      "constraints": [
        "Follow the approved design specification",
        "Create artifacts in appropriate stage directories",
        "Write content that follows layer-stage conventions",
        "Do NOT modify production layer_0 systems directly",
        "Do NOT proceed to ReviewMode until implementation is complete"
      ],
      "contains": [
        "orch:ImplementPersona1",
        "orch:ImplementPersona2"
      ],
      "isolatedState": "orch:ImplementModeState",
      "precedes": [
        "orch:ReviewMode"
      ]
    },
    {
      "@id": "orch:ReviewMode",
      "@type": "gab:Mode",
      "purpose": "Validate output quality, ensure research rigor, prepare for delivery",
      "constraints": [
        "Validate all artifacts against design specifications",
        "Ensure research sources are cited",
        "Check layer-stage hierarchy compliance",
        "Write results to hand_off_documents/outgoing/",
        "Transition back to ReceiveMode after delivery"
      ],
      "contains": [
        "orch:ReviewPersona1",
        "orch:ReviewPersona2"
      ],
      "isolatedState": "orch:ReviewModeState",
      "precedes": [
        "orch:ReceiveMode"
      ]
    },
    {

{
  "@context": {
    "@vocab": "https://layer-stage.dev/agent/",
    "gab": "https://aalang.dev/gab/",
    "ads": "https://layer-stage.dev/agent-delegation-system/"
  },
  "@graph": [
    {
      "@id": "ads:AgentDelegationSystemAgent",
      "@type": "gab:LLMAgent",
      "purpose": "Entity manager for the agent delegation system — coordinates stage work and child features",
      "layer": 1,
      "scope": "sub-feature",
      "entityPath": "./",
      "identity": {
        "role": "Agent delegation system manager",
        "domain": "Stage delegation, agent context models, manager-agent communication, stage reports, context chains",
        "parent": "../../../0AGNOSTIC.md",
        "children": ["memory_system", "multi_agent_system"]
      },
      "capabilities": [
        "Delegate to stage agents (01-11)",
        "Read stage reports for async status",
        "Coordinate child sub-features (memory_system, multi_agent_system)",
        "Manage .0agnostic/ resources (knowledge, rules, protocols)",
        "Produce handoff documents for parent feature"
      ],
      "constraints": [
        "Do not do stage work directly — delegate to stage agents",
        "Read stage reports for status — do not load full stage context",
        "Scope limited to agent delegation — escalate cross-feature requests",
        "Respect layer_0 safety rules"
      ],
      "contextModel": {
        "static": ["0AGNOSTIC.md", "CLAUDE.md (auto-generated)", ".0agnostic/09_handoff_documents/stage_overview.md"],
        "dynamic": ["Stage reports (outputs/reports/stage_report.md)", ".0agnostic/01_knowledge/", ".0agnostic/02_rules/", "Child entity 0AGNOSTIC.md files"]
      }
    }
  ]
}

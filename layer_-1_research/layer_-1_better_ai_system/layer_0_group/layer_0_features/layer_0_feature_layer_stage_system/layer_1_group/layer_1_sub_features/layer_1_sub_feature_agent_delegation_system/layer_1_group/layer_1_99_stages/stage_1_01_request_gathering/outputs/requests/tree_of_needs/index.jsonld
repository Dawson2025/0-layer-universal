  "rootNeed": {
    "@id": "00_agents_delegate_effectively/",
    "@type": "RootNeed",
    "name": "Agents Delegate Effectively",
    "description": "Managers delegate work to specialized stage agents and sub-feature agents without carrying operational knowledge. Memory and multi-agent systems work together coherently.",

    "branches": [
      {
        "@id": "00_agents_delegate_effectively/01_delegation_model/",
        "@type": "Branch",
        "name": "Delegation Model",
        "description": "How managers delegate without carrying operational knowledge",
        "rel:mapsTo": {

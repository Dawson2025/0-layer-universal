            "name": "Stage Delegation",
            "description": "How a manager hands off work to a stage agent"
          },
          {
            "@id": "00_agents_delegate_effectively/01_delegation_model/need_02_stage_reports/",
            "@type": "Need",
            "name": "Stage Reports",
            "description": "How a manager knows what happened in a stage without loading all stage details"
          },
          {
            "@id": "00_agents_delegate_effectively/01_delegation_model/need_03_agent_context_model/",
            "@type": "Need",
            "name": "Agent Context Model",
            "description": "What each agent type knows in its static vs dynamic context"
          }
        ]
      },
      {
        "@id": "00_agents_delegate_effectively/02_memory_integration/",
        "@type": "Branch",

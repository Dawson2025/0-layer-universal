        },
        "needs": [
          {
            "@id": "00_agents_delegate_effectively/02_memory_integration/need_01_context_chain_support/",
            "@type": "Need",
            "name": "Context Chain Support",
            "description": "How context chains enable delegation decisions"
          },
          {
            "@id": "00_agents_delegate_effectively/02_memory_integration/need_02_handoff_protocols/",
            "@type": "Need",
            "name": "Handoff Protocols",
            "description": "How context is preserved when transitioning between agents"
          },
          {

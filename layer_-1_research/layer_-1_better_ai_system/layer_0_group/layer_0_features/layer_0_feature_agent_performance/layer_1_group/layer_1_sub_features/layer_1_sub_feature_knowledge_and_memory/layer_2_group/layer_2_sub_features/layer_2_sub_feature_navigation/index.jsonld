{
  "@context": {
    "@vocab": "https://layer-stage.dev/schema#",
    "nav": "https://layer-stage.dev/nav#",
    "rel": "https://layer-stage.dev/rel#",
    "trigger": "https://layer-stage.dev/trigger#"
  },

  "@id": "layer_1_sub_feature_navigation_system",
  "@type": "SubFeature",
  "layer": 1,

  "name": "Navigation System",
  "description": "JSON-LD based navigation, links, and triggers for agent context delivery",

  "nav:parent": {
    "@id": "../",
    "name": "layer_0_feature_context_framework"
  },

  "nav:siblings": [
    {"@id": "../layer_1_sub_feature_context_system/", "name": "Context System"},
    {"@id": "../layer_1_sub_feature_dynamic_memory/", "name": "Dynamic Memory"},
    {"@id": "../layer_1_sub_feature_context_visualization/", "name": "Context Visualization"}
  ],

  "conventions": {
    "childNaming": {
      "pattern": "layer_{N+1}_{type}_{name}",
      "currentLayer": 1,
      "childLayer": 2,
      "example": "layer_2_component_link_validator"
    }
  },

  "rel:treeOfNeedsBranch": {
    "branch": "06_context_flow",
    "primaryNeeds": [
      "need_02_context_propagation_works",
      "need_05_entry_points_right_detail",
      "need_06_navigation_to_deeper_details"
    ]
  },

  "children": [
    {
      "@id": "layer_2_component_jsonld_schema/",
      "name": "JSON-LD Schema",
      "description": "Vocabulary definitions for layer-stage navigation",
      "status": "prototype"
    },
    {
      "@id": "layer_2_component_index_files/",
      "name": "Index Files",
      "description": "index.jsonld patterns for registries and navigation",
      "status": "prototype"
    },
    {
      "@id": "layer_2_component_link_validator/",
      "name": "Link Validator",
      "description": "Tool to validate @id links resolve correctly",
      "status": "planned"
    }
  ],

  "prototype": {
    "location": "Prototype was at layer_1_sub_feature_layer_stage_system, now consolidated here",
    "files": [
      "index.jsonld patterns",
      ".claude/schema/layer-stage-schema.jsonld",
      "Various index.jsonld files demonstrating navigation"
    ]
  }
}

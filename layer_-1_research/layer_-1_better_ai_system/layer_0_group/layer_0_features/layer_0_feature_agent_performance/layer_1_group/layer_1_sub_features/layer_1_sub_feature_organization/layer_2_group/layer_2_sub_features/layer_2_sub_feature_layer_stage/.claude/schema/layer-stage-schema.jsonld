{
  "@context": {
    "@vocab": "https://layer-stage.dev/schema#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "xsd": "http://www.w3.org/2001/XMLSchema#"
  },

  "@graph": [
    {
      "@id": "https://layer-stage.dev/schema#",
      "@type": "rdfs:Ontology",
      "rdfs:label": "Layer-Stage Navigation Schema",
      "rdfs:comment": "Schema for AI agent navigation in layer-stage hierarchies",
      "version": "1.0.0"
    },

    {
      "@id": "https://layer-stage.dev/schema#Feature",
      "@type": "rdfs:Class",
      "rdfs:label": "Feature",
      "rdfs:comment": "A feature within the layer-stage system"
    },
    {
      "@id": "https://layer-stage.dev/schema#LayerGroup",
      "@type": "rdfs:Class",
      "rdfs:label": "LayerGroup",
      "rdfs:comment": "A group of content at a specific layer level (layer_N_group)"
    },
    {
      "@id": "https://layer-stage.dev/schema#Stage",
      "@type": "rdfs:Class",
      "rdfs:label": "Stage",
      "rdfs:comment": "One of the 11 development stages (01-11)"
    },
    {
      "@id": "https://layer-stage.dev/schema#TreeOfNeeds",
      "@type": "rdfs:Class",
      "rdfs:label": "TreeOfNeeds",
      "rdfs:comment": "Hierarchical requirements structure"
    },
    {
      "@id": "https://layer-stage.dev/schema#SkillsIndex",
      "@type": "rdfs:Class",
      "rdfs:label": "SkillsIndex",
      "rdfs:comment": "Index of available skills and workflows"
    },

    {
      "@id": "https://layer-stage.dev/nav#parent",
      "@type": "rdfs:Property",
      "rdfs:label": "parent",
      "rdfs:comment": "Link to parent entity in hierarchy"
    },
    {
      "@id": "https://layer-stage.dev/nav#children",
      "@type": "rdfs:Property",
      "rdfs:label": "children",
      "rdfs:comment": "Links to child entities"
    },
    {
      "@id": "https://layer-stage.dev/nav#skills",
      "@type": "rdfs:Property",
      "rdfs:label": "skills",
      "rdfs:comment": "Link to skills folder/index"
    },
    {
      "@id": "https://layer-stage.dev/nav#treeOfNeeds",
      "@type": "rdfs:Property",
      "rdfs:label": "treeOfNeeds",
      "rdfs:comment": "Link to tree of needs for this entity"
    },
    {
      "@id": "https://layer-stage.dev/nav#stages",
      "@type": "rdfs:Property",
      "rdfs:label": "stages",
      "rdfs:comment": "Link to stages folder with stage index"
    },
    {
      "@id": "https://layer-stage.dev/nav#previous",
      "@type": "rdfs:Property",
      "rdfs:label": "previous",
      "rdfs:comment": "Link to previous stage in sequence"
    },
    {
      "@id": "https://layer-stage.dev/nav#next",
      "@type": "rdfs:Property",
      "rdfs:label": "next",
      "rdfs:comment": "Link to next stage in sequence"
    },
    {
      "@id": "https://layer-stage.dev/nav#context",
      "@type": "rdfs:Property",
      "rdfs:label": "context",
      "rdfs:comment": "Link to CLAUDE.md or equivalent context file"
    },

    {
      "@id": "https://layer-stage.dev/trigger#onSessionStart",
      "@type": "rdfs:Property",
      "rdfs:label": "onSessionStart",
      "rdfs:comment": "Actions to take when starting a session at this entity"
    },
    {
      "@id": "https://layer-stage.dev/trigger#onEnter",
      "@type": "rdfs:Property",
      "rdfs:label": "onEnter",
      "rdfs:comment": "Actions to take when entering this entity"
    },
    {
      "@id": "https://layer-stage.dev/trigger#onEntityCreation",
      "@type": "rdfs:Property",
      "rdfs:label": "onEntityCreation",
      "rdfs:comment": "Skill to invoke when creating child entities"
    },
    {
      "@id": "https://layer-stage.dev/trigger#skill",
      "@type": "rdfs:Property",
      "rdfs:label": "skill",
      "rdfs:comment": "Link to skill/workflow for this context"
    },
    {
      "@id": "https://layer-stage.dev/trigger#when",
      "@type": "rdfs:Property",
      "rdfs:label": "when",
      "rdfs:comment": "Condition that triggers this skill"
    },

    {
      "@id": "https://layer-stage.dev/rel#satisfiesNeed",
      "@type": "rdfs:Property",
      "rdfs:label": "satisfiesNeed",
      "rdfs:comment": "Link to the need this entity satisfies"
    },
    {
      "@id": "https://layer-stage.dev/rel#siblings",
      "@type": "rdfs:Property",
      "rdfs:label": "siblings",
      "rdfs:comment": "Links to related entities at same level"
    },
    {
      "@id": "https://layer-stage.dev/rel#mapsTo",
      "@type": "rdfs:Property",
      "rdfs:label": "mapsTo",
      "rdfs:comment": "How this need maps to further layering"
    },
    {
      "@id": "https://layer-stage.dev/rel#informsFurtherLayering",
      "@type": "rdfs:Property",
      "rdfs:label": "informsFurtherLayering",
      "rdfs:comment": "How tree hierarchy informs child entity organization"
    },

    {
      "@id": "https://layer-stage.dev/schema#SubFeature",
      "@type": "rdfs:Class",
      "rdfs:label": "SubFeature",
      "rdfs:comment": "A sub-feature within a feature (layer N+1)"
    },
    {
      "@id": "https://layer-stage.dev/schema#Component",
      "@type": "rdfs:Class",
      "rdfs:label": "Component",
      "rdfs:comment": "A reusable component (layer N+1 or deeper)"
    },
    {
      "@id": "https://layer-stage.dev/schema#Subproject",
      "@type": "rdfs:Class",
      "rdfs:label": "Subproject",
      "rdfs:comment": "A subproject within a project (layer N+1)"
    },
    {
      "@id": "https://layer-stage.dev/schema#FeaturesRegistry",
      "@type": "rdfs:Class",
      "rdfs:label": "FeaturesRegistry",
      "rdfs:comment": "Registry of features at a layer level"
    },
    {
      "@id": "https://layer-stage.dev/schema#ComponentsRegistry",
      "@type": "rdfs:Class",
      "rdfs:label": "ComponentsRegistry",
      "rdfs:comment": "Registry of components at a layer level"
    },
    {
      "@id": "https://layer-stage.dev/schema#SubprojectsRegistry",
      "@type": "rdfs:Class",
      "rdfs:label": "SubprojectsRegistry",
      "rdfs:comment": "Registry of subprojects at a layer level"
    },

    {
      "@id": "https://layer-stage.dev/schema#entityTypes",
      "@type": "rdfs:Property",
      "rdfs:label": "entityTypes",
      "rdfs:comment": "Definitions of entity types with naming patterns",
      "value": {
        "Feature": {
          "pattern": "layer_{N}_feature_{name}",
          "example": "layer_0_feature_context_framework",
          "description": "High-level features that address tree of needs branches"
        },
        "SubFeature": {
          "pattern": "layer_{N}_sub_feature_{name}",
          "example": "layer_1_sub_feature_context_system",
          "description": "Sub-features within features (note: underscore in sub_feature)"
        },
        "Component": {
          "pattern": "layer_{N}_component_{name}",
          "example": "layer_2_component_link_validator",
          "description": "Reusable components shared across features"
        },
        "Subproject": {
          "pattern": "layer_{N}_subproject_{name}",
          "example": "layer_1_subproject_prototype",
          "description": "Subprojects within projects"
        }
      }
    },

    {
      "@id": "https://layer-stage.dev/schema#conventions",
      "@type": "rdfs:Property",
      "rdfs:label": "conventions",
      "rdfs:comment": "Conventions for child entity naming and structure"
    },
    {
      "@id": "https://layer-stage.dev/schema#childNaming",
      "@type": "rdfs:Property",
      "rdfs:label": "childNaming",
      "rdfs:comment": "Naming pattern for child entities"
    },
    {
      "@id": "https://layer-stage.dev/schema#layer",
      "@type": "rdfs:Property",
      "rdfs:label": "layer",
      "rdfs:comment": "The layer number of this entity (0, 1, 2, -1, etc.)"
    }
  ]
}

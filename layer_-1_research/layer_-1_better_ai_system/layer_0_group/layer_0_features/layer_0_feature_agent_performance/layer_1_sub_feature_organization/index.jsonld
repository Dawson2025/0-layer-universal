{
  "@context": {
    "@vocab": "https://layer-stage.dev/schema#",
    "nav": "https://layer-stage.dev/nav#",
    "rel": "https://layer-stage.dev/rel#"
  },

  "@id": "layer_0_feature_structure_framework",
  "@type": "Feature",
  "layer": 0,

  "name": "Structure Framework",
  "description": "Systems for organizing projects using the layer-stage pattern and setup/configuration",

  "nav:parent": {
    "@id": "../",
    "name": "layer_0_features"
  },

  "conventions": {
    "childNaming": {
      "pattern": "layer_{N+1}_{type}_{name}",
      "currentLayer": 0,
      "childLayer": 1,
      "example": "layer_1_sub_feature_layer_stage_system"
    }
  },

  "rel:treeOfNeedsBranch": {
    "note": "Supports organization across all branches"
  },

  "children": [
    {
      "@id": "layer_1_sub_feature_layer_stage_system/",
      "@type": "SubFeature",
      "name": "Layer Stage System",
      "description": "Layer-stage organization patterns and improvements",
      "formerName": "better_layer_stage_system"
    },
    {
      "@id": "layer_1_sub_feature_setup_system/",
      "@type": "SubFeature",
      "name": "Setup System",
      "description": "Project setup and configuration",
      "formerName": "better_setup_system"
    }
  ]
}

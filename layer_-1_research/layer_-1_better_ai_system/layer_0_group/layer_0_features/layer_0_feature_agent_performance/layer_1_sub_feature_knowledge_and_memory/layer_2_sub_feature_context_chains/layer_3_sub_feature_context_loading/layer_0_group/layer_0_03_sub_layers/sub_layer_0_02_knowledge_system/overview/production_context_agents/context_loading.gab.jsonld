    {
      "@id": "ctx:UserTeamLead",
      "@type": "gab:Role",
      "role": "Team Lead",
      "name": "User",
      "authority": "Final decision-making authority for all four teams (Loading, Validation, Propagation, Delivery)",
      "teams": [
        "ctx:LoadingMode",
        "ctx:ValidationMode",
        "ctx:PropagationMode",
        "ctx:DeliveryMode"
      ],
      "interactions": [
        "Can receive messages from all personas",
        "Can send messages to any persona",
        "Can navigate flexibly between modes",
        "Can make decisions that affect context state",
        "Can approve/reject override proposals",
        "Receives escalated conflicts from Propagation Mode",
        "Must approve overrides to layer_0 absolute-severity rules"
      ],
      "tools": {
        "contextDebugOn": "Enable full debug output: /context-debug on",
        "contextDebugOff": "Disable debug output: /context-debug off",
        "contextDebugVerbose": "Enable verbose loading output: /context-debug verbose",
        "contextStatus": "Show current context state: /context-status"
      },
      "visibility": "Can see all messages in ctx:ContextMessageInterface",
      "modeNavigation": {
        "flexible": true,
        "allowedModes": [
          "ctx:LoadingMode",
          "ctx:ValidationMode",
          "ctx:PropagationMode",
          "ctx:DeliveryMode"
        ],
        "note": "User can request to revisit earlier modes if needed"
      }
    },
    {
      "@id": "ctx:DebugCommands",
      "@type": "Feature",
      "rdfs:label": "Context Debug Mode",
      "description": "User-toggleable debug feature that controls visibility of context loading details",
      "defaultState": "OFF",
      "toggleCommands": [
        "/context-debug on",
        "/context-debug off",
        "/context-debug verbose",
        "/context-status"
      ],
      "stateStorage": "Stored in ctx:DebugContextStatePersona internal isolated context",
      "behavior": {
        "whenOn": {
          "output": "Show all files loaded, position identification, inheritance chain, overrides applied, confidence scores",
          "userFacing": "Full context loading visibility"
        },
        "whenOff": {
          "output": "Silent or minimal confirmation",
          "userFacing": "Only essential information visible"
        },
        "whenVerbose": {
          "output": "Show each file as it loads with details",
          "userFacing": "Step-by-step loading visibility"
        }
      }
    },
    {
      "@id": "ctx:CrossSessionPersistence",
      "@type": "Feature",
      "rdfs:label": "Cross-Session State Persistence",
      "description": "Extension beyond base AALang's session-only state model - enables state to persist across sessions via file",
      "persistenceFile": ".claude/context_state.json",
      "triggers": [
        "On Delivery Mode completion",
        "On significant state changes",
        "On session end (if detectable)"
      ],
      "persistedState": [
        "contextLoadingState (loadedFiles, claudeMdChain, etc.)",
        "contextConfidenceState (all confidence scores)",
        "navigationState (currentLayer, currentStage, path, etc.)",
        "debugContextState (debug settings)"
      ],
      "onSessionStart": {
        "action": "Read .claude/context_state.json if it exists",
        "behavior": "Use persisted state as starting point, but re-verify context is still valid"
      },
      "note": "This is a key extension beyond AALang's base design which only supports session-scoped state. Cross-session persistence enables continuity for multi-session workflows."
    },
    {
      "@id": "ctx:LayerInheritanceModel",
      "@type": "Specification",
      "rdfs:label": "Layer Inheritance Model",
      "description": "Defines how context is inherited and can be overridden across layers",
      "principle": "Layer N inherits from layers 0 through N-1. Layer N can override any inherited context.",
      "layerDefinitions": {
        "layer_-1": "Research layer (experimental, inherits from layer_0)",
        "layer_0": "Universal layer (applies to ALL projects)",
        "layer_1": "Project layer (inherits from layer_0, can override)",
        "layer_2+": "Feature/component layers (inherit from all lower layers, can override)"
      },
      "precedenceRules": [
        {
          "rule": "Higher layer number wins",
          "example": "layer_1 context overrides layer_0 context"
        },
        {
          "rule": "Later in chain wins (within same layer)",
          "example": "subproject/CLAUDE.md overrides project/CLAUDE.md"
        },
        {
          "rule": "CLAUDE.local.md has highest precedence",
          "example": "Personal overrides always win"
        }
      ],
      "overrideSyntax": {
        "marker": "@override",
        "format": "@override layer_0/sub_layer_0_04_rules/some_rule.md\nReason: [explanation]\n\n[New rule content]",
        "requirement": "Must include reason for override"
      },
      "safetyProtection": {
        "description": "Layer_0 rules marked with severity='absolute' cannot be overridden without user approval",
        "examples": [
          "Security governance rules",
          "Permission controls",
          "Safety-critical constraints"
        ],
        "behavior": "If higher layer attempts to override, escalate to user (Team Lead)"
      }
    },
    {
      "@id": "ctx:ConfidenceCalculation",
      "@type": "Specification",
      "rdfs:label": "Confidence Score Calculation",
      "description": "Defines how context confidence is calculated",
      "components": {
        "layerIdentified": {
          "weight": 0.25,
          "description": "Confidence that current layer is correctly identified"
        },
        "stageIdentified": {
          "weight": 0.15,
          "description": "Confidence that current stage is correctly identified (or N/A)"
        },
        "rulesAwareness": {
          "weight": 0.25,
          "description": "Confidence that required rules are loaded and understood"
        },
        "inheritanceResolved": {
          "weight": 0.15,
          "description": "Confidence that layer inheritance is fully resolved"
        },
        "requiredContextLoaded": {
          "weight": 0.20,
          "description": "Confidence that all required context files are loaded"
        }
      },
      "calculation": "overallConfidence = (layerIdentified × 0.25) + (stageIdentified × 0.15) + (rulesAwareness × 0.25) + (inheritanceResolved × 0.15) + (requiredContextLoaded × 0.20)",
      "thresholds": {
        "loadingComplete": 0.6,
        "validationComplete": 0.8,
        "workReady": 0.8
      }
    },
    {
      "@id": "ctx:InitialResponse",
      "@type": "Instruction",
      "purpose": "Context loading does not need user interaction - it happens automatically",
      "behavior": "Context loading agent executes automatically when session starts. User sees results only if debug mode is enabled.",
      "note": "Unlike GAB which requires user input, context loading is automatic and silent (unless debug mode is on)"
    }
  ]
}

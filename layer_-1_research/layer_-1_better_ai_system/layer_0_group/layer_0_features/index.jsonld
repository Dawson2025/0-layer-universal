{
  "@context": {
    "@vocab": "https://layer-stage.dev/schema#",
    "nav": "https://layer-stage.dev/nav#",
    "rel": "https://layer-stage.dev/rel#",
    "trigger": "https://layer-stage.dev/trigger#"
  },

  "@id": "layer_0_features",
  "@type": "FeaturesRegistry",
  "layer": 0,

  "name": "Layer 0 Features",
  "description": "High-level features for the better_ai_system research project",

  "nav:parent": {
    "@id": "../",
    "name": "layer_0_group"
  },

  "nav:siblings": [
    {"@id": "../layer_0_components/", "name": "Components"},
    {"@id": "../layer_0_subprojects/", "name": "Subprojects"}
  ],

  "conventions": {
    "childNaming": {
      "pattern": "layer_{N}_{type}_{name}",
      "currentLayer": 0,
      "example": "layer_0_feature_context_framework",
      "note": "Features are at same layer as registry; sub_features inside are layer+1"
    }
  },

  "trigger:onEntityCreation": {
    "skill": "../.claude/skills/entity-creation/",
    "loads": ["conventions.childNaming"]
  },

  "features": [
    {
      "@id": "layer_0_feature_context_framework/",
      "@type": "Feature",
      "name": "Context Framework",
      "description": "Context delivery, memory, and navigation systems",
      "rel:treeOfNeedsBranch": ["06_context_flow", "01_capable"],
      "children": [
        "layer_1_sub_feature_context_system",
        "layer_1_sub_feature_dynamic_memory",
        "layer_1_sub_feature_navigation_system"
      ]
    },
    {
      "@id": "layer_0_feature_structure_framework/",
      "@type": "Feature",
      "name": "Structure Framework",
      "description": "Layer-stage organization and setup systems",
      "children": [
        "layer_1_sub_feature_layer_stage_system",
        "layer_1_sub_feature_setup_system"
      ]
    },
    {
      "@id": "layer_0_feature_governance_framework/",
      "@type": "Feature",
      "name": "Governance Framework",
      "description": "Rules and manager hierarchy systems",
      "rel:treeOfNeedsBranch": ["03_trustworthy"],
      "children": [
        "layer_1_sub_feature_rules_system",
        "layer_1_sub_feature_manager_hierarchy"
      ]
    },
    {
      "@id": "layer_0_feature_tooling_framework/",
      "@type": "Feature",
      "name": "Tooling Framework",
      "description": "Automation and documentation systems",
      "rel:treeOfNeedsBranch": ["02_continuous", "04_observable"],
      "children": [
        "layer_1_sub_feature_automation_system",
        "layer_1_sub_feature_documentation_system"
      ]
    }
  ]
}

{
  "@context": {
    "@vocab": "https://layer-stage.dev/schema#",
    "nav": "https://layer-stage.dev/nav#",
    "rel": "https://layer-stage.dev/rel#",
    "trigger": "https://layer-stage.dev/trigger#"
  },

  "@id": "layer_0_features",
  "@type": "FeaturesRegistry",
  "layer": 0,

  "name": "Layer 0 Features",
  "description": "High-level features for the better_ai_system research project",

  "nav:parent": {
    "@id": "../",
    "name": "layer_0_group"
  },

  "nav:siblings": [
    {"@id": "../layer_0_components/", "name": "Components"},
    {"@id": "../layer_0_subprojects/", "name": "Subprojects"}
  ],

  "conventions": {
    "childNaming": {
      "pattern": "layer_{N}_{type}_{name}",
      "currentLayer": 0,
      "example": "layer_0_feature_context_framework",
      "note": "Features are at same layer as registry; sub_features inside are layer+1"
    }
  },

  "trigger:onEntityCreation": {
    "skill": "../.claude/skills/entity-creation/",
    "loads": ["conventions.childNaming"]
  },

  "features": [
    {
      "@id": "layer_0_feature_agent_performance/",
      "@type": "Feature",
      "name": "Agent Performance",
      "description": "Unified research into all aspects of AI agent performance — consolidates knowledge/memory, scaling, AALang, organization, and tooling",
      "note": "Phase 2 complete: content migrated from 6 former features (context_framework, structure_framework, governance_framework, tooling_framework, multi_agent_orchestration, aalang_integration)",
      "rel:treeOfNeedsBranch": ["01_capable", "02_continuous", "03_trustworthy", "04_observable", "06_context_flow"],
      "children": [
        "layer_1_sub_feature_knowledge_and_memory",
        "layer_1_sub_feature_performance_at_scale",
        "layer_1_sub_feature_aalang",
        "layer_1_sub_feature_organization",
        "layer_1_sub_feature_tooling"
      ]
    }
  ]
}

      "isWorkflow": true
    },
    {
      "@id": "handoff-protocol/",
      "name": "handoff-protocol",
      "description": "Protocol for session handoffs at current stage",
      "trigger:when": "Creating handoff documents",
      "invocable": false
    }
  ],

  "trigger:patterns": {

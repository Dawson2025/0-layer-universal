{
  "@context": {
    "@vocab": "https://layer-stage.dev/schema#",
    "nav": "https://layer-stage.dev/nav#",
    "rel": "https://layer-stage.dev/rel#"
  },

  "@id": "layer_0_feature_governance_framework",
  "@type": "Feature",
  "layer": 0,

  "name": "Governance Framework",
  "description": "Systems for rules management and agent hierarchy/delegation",

  "nav:parent": {
    "@id": "../",
    "name": "layer_0_features"
  },

  "conventions": {
    "childNaming": {
      "pattern": "layer_{N+1}_{type}_{name}",
      "currentLayer": 0,
      "childLayer": 1,
      "example": "layer_1_sub_feature_rules_system"
    }
  },

  "rel:treeOfNeedsBranch": {
    "primary": "03_trustworthy",
    "needs": [
      "need_01_rule_compliant",
      "need_02_predictable",
      "need_03_bounded"
    ]
  },

  "children": [
    {
      "@id": "layer_1_sub_feature_rules_system/",
      "@type": "SubFeature",
      "name": "Rules System",
      "description": "Rule discovery, application, and compliance",
      "formerName": "ai_rules_system"
    },
    {
      "@id": "layer_1_sub_feature_manager_hierarchy/",
      "@type": "SubFeature",
      "name": "Manager Hierarchy",
      "description": "Agent hierarchy and delegation patterns",
      "formerName": "ai_manager_hierarchy_system"
    }
  ]
}

{
  "@context": {
    "@vocab": "https://layer-stage.dev/schema#",
    "nav": "https://layer-stage.dev/nav#",
    "rel": "https://layer-stage.dev/rel#"
  },

  "@id": "layer_0_feature_context_framework",
  "@type": "Feature",
  "layer": 0,

  "name": "Context Framework",
  "description": "Systems for context delivery, memory persistence, and navigation to ensure agents receive the right information at the right time",

  "nav:parent": {
    "@id": "../",
    "name": "layer_0_features"
  },

  "conventions": {
    "childNaming": {
      "pattern": "layer_{N+1}_{type}_{name}",
      "currentLayer": 0,
      "childLayer": 1,
      "example": "layer_1_sub_feature_context_system"
    }
  },

  "rel:treeOfNeedsBranch": {
    "primary": "06_context_flow",
    "secondary": "01_capable",
    "needs": [
      "need_01_no_amnesia",
      "need_02_context_propagation_works",
      "need_03_static_context_available",
      "need_04_dynamic_context_available",
      "need_05_entry_points_right_detail",
      "need_06_navigation_to_deeper_details"
    ]
  },

  "children": [
    {
      "@id": "layer_1_sub_feature_context_system/",
      "@type": "SubFeature",
      "name": "Context System",
      "description": "Core context loading and management",
      "formerName": "ai_context_system"
    },
    {
      "@id": "layer_1_sub_feature_dynamic_memory/",
      "@type": "SubFeature",
      "name": "Dynamic Memory",
      "description": "Session memory and state persistence",
      "formerName": "ai_dynamic_memory_system"
    },
    {
      "@id": "layer_1_sub_feature_navigation_system/",
      "@type": "SubFeature",
      "name": "Navigation System",
      "description": "JSON-LD navigation, links, and triggers",
      "note": "New - contains JSON-LD prototype"
    },
    {
      "@id": "layer_1_sub_feature_context_visualization/",
      "@type": "SubFeature",
      "name": "Context Visualization",
      "description": "Diagrams and tools for visualizing context flow, architecture, and propagation",
      "note": "New - provides visual understanding of context system"
    }
  ],

  "docs": {
    "@id": "docs/",
    "onboarding": {
      "@id": "docs/onboarding.md",
      "name": "Context Framework Onboarding",
      "description": "Guide for understanding how context flows through the system"
    }
  }
}

{
  "@context": {
    "@vocab": "https://layer-stage.dev/schema#",
    "nav": "https://layer-stage.dev/nav#",
    "trigger": "https://layer-stage.dev/trigger#"
  },

  "@id": "layer_0_group",
  "@type": "LayerGroup",
  "layer": 0,

  "name": "Layer 0 Group",
  "description": "Children group for the better_ai_system research project",

  "nav:parent": {
    "@id": "../",
    "name": "layer_-1_better_ai_system"
  },

  "conventions": {
    "childNaming": {
      "pattern": "layer_{N}_{type}_{name}",
      "currentLayer": 0,
      "types": {
        "feature": "layer_0_feature_{name}",
        "component": "layer_0_component_{name}"
      },
      "examples": [
        "layer_0_feature_agent_performance"
      ]
    }
  },

  "trigger:onEntityCreation": {
    "skill": ".claude/skills/entity-creation/",
    "loads": ["conventions.childNaming"],
    "validates": {
      "namePattern": "^layer_\\d+_(feature|sub_feature|component)_.+$"
    },
    "reference": "@imports/entity_structure.md"
  },

  "nav:children": [
    {
      "@id": "layer_0_00_layer_registry/",
      "@type": "LayerRegistry",
      "name": "Layer Registry",
      "description": "Proposals and registry for layer_0 children"
    },
    {
      "@id": "layer_0_features/",
      "@type": "FeaturesRegistry",
      "name": "Features",
      "description": "Research features (1 consolidated: agent_performance)"
    }
  ]
}

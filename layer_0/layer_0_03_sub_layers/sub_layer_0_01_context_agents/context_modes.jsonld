{
  "@context": {
    "@vocab": "https://aalang.org/",
    "gab": "https://aalang.org/gab/",
    "ctx": "https://layer-stage.dev/context/",
    "ls": "https://layer-stage.dev/"
  },
  "@graph": [
    {
      "@id": "ctx:ContextLoadingMode",
      "@type": "gab:Mode",
      "name": "Context Loading Mode",
      "phase": 1,
      "description": "Phase 1: Load all context files in the CLAUDE.md chain",

      "entryActions": [
        "Initialize ContextLoadingStateActor with empty state",
        "Clear previous session context if new session",
        "Detect if inside layer-stage system"
      ],

      "responsibilities": [
        "Load ~/.claude/CLAUDE.md (user global, if exists)",
        "Load ~/CLAUDE.md (user root, if exists)",
        "Traverse upward from cwd loading all CLAUDE.md files",
        "Load .claude/rules/*.md files at each level",
        "Load CLAUDE.local.md (personal overrides, if exists)",
        "For each file loaded:",
        "  - Record in ContextLoadingStateActor.loadedFiles",
        "  - Track layer number for inheritance",
        "  - Estimate token count",
        "Calculate initial confidence score"
      ],

      "loadingOrder": {
        "description": "Order in which context files are loaded",
        "sequence": [
          { "step": 1, "file": "~/.claude/CLAUDE.md", "scope": "user-global" },
          { "step": 2, "file": "~/CLAUDE.md", "scope": "user-root" },
          { "step": 3, "file": "[ancestors]/CLAUDE.md", "scope": "path-traversal", "note": "All CLAUDE.md from ~ to cwd" },
          { "step": 4, "file": ".claude/rules/*.md", "scope": "per-project", "note": "At project roots" },
          { "step": 5, "file": "CLAUDE.local.md", "scope": "personal", "note": "Highest precedence for overrides" }
        ]
      },

      "exitCondition": {
        "check": "ContextConfidenceStateActor.overallConfidence >= 0.6",
        "onFail": "Continue loading more context or flag gaps"
      },

      "isolatedState": {
        "filesToLoad": { "@type": "array", "description": "Queue of files to load" },
        "currentFileIndex": { "@type": "integer" },
        "loadErrors": { "@type": "array", "description": "Files that failed to load" }
      }
    },

    {
      "@id": "ctx:ContextValidationMode",
      "@type": "gab:Mode",
      "name": "Context Validation Mode",
      "phase": 2,
      "description": "Phase 2: Validate context completeness and identify current position",

      "entryActions": [
        "Parse cwd to determine layer/stage/sub_layer",
        "Update NavigationStateActor with position"
      ],

      "responsibilities": [
        "Identify current layer (-1, 0, 1, 2, ...)",
        "Identify current stage (01-11, if applicable)",
        "Identify current sub_layer (if nested)",
        "Build inheritance chain:",
        "  - What layers does current position inherit from?",
        "  - In what order?",
        "Check if required context is loaded:",
        "  - sub_layer_0_04_rules (required for all work)",
        "  - sub_layer_0_05_protocols (at session start)",
        "  - Layer-specific context for current layer",
        "Update ContextConfidenceStateActor scores",
        "Flag any missing required context"
      ],

      "positionDetection": {
        "layerPattern": "layer_(-?\\d+)",
        "stagePattern": "stage_(-?\\d+)_(0[1-9]|1[01])",
        "subLayerPattern": "sub_layer_(-?\\d+)_(\\d+)_(.+)"
      },

      "exitCondition": {
        "check": "ContextConfidenceStateActor.overallConfidence >= 0.8",
        "onFail": "Identify gaps, attempt to load missing context"
      },

      "fallbackActions": [
        "If layer not identified: check parent directories",
        "If rules not loaded: explicitly load sub_layer_0_04_rules",
        "If confidence still low: escalate to user for guidance"
      ]
    },

    {
      "@id": "ctx:ContextPropagationMode",
      "@type": "gab:Mode",
      "name": "Context Propagation Mode",
      "phase": 3,
      "description": "Phase 3: Resolve layer inheritance and apply overrides",

      "responsibilities": [
        "Build effective context by applying inheritance:",
        "  1. Start with layer_0 context (universal base)",
        "  2. Apply layer_1 context (inherits + can override)",
        "  3. Apply layer_2+ context (inherits + can override)",
        "  4. Apply CLAUDE.local.md (personal overrides)",
        "Detect explicit overrides:",
        "  - Look for @override markers",
        "  - Record in ContextLoadingStateActor.overrides",
        "Detect implicit conflicts:",
        "  - Same rule defined differently in multiple layers",
        "  - Flag for resolution",
        "Resolve conflicts using precedence:",
        "  - Higher layer number wins (can override lower)",
        "  - Later in chain wins (within same layer)",
        "  - Explicit @override wins over implicit"
      ],

      "inheritanceRules": {
        "description": "How layers inherit and override",
        "principles": [
          "Layer 0 is the universal base - provides defaults",
          "Layer 1+ inherits ALL of Layer 0 automatically",
          "Layer 1+ CAN override Layer 0 when project needs differ",
          "Overrides should be explicit (@override marker preferred)",
          "Later files in chain override earlier (same-layer precedence)",
          "CLAUDE.local.md has highest precedence (personal overrides)"
        ],
        "overrideMarker": "@override",
        "example": {
          "scenario": "Layer 1 project needs different git commit format",
          "layer0Rule": "Use conventional commits",
          "layer1Override": "@override: Use project-specific commit format",
          "result": "Layer 1 rule applies in layer 1, Layer 0 rule applies elsewhere"
        }
      },

      "exitCondition": {
        "check": "All conflicts resolved OR escalated to user",
        "output": "Effective context with inheritance applied"
      },

      "isolatedState": {
        "conflicts": { "@type": "array", "description": "Detected conflicts" },
        "resolutions": { "@type": "array", "description": "How conflicts were resolved" },
        "escalations": { "@type": "array", "description": "Conflicts requiring user input" }
      }
    },

    {
      "@id": "ctx:ContextDeliveryMode",
      "@type": "gab:Mode",
      "name": "Context Delivery Mode",
      "phase": 4,
      "description": "Phase 4: Present context summary and confirm ready for work",

      "responsibilities": [
        "If DebugContextStateActor.debugMode is true:",
        "  - Present full context summary",
        "  - Show all loaded files with layers",
        "  - Show current position in hierarchy",
        "  - Show inheritance chain",
        "  - Show any overrides applied",
        "  - Show confidence scores",
        "If debugMode is false:",
        "  - Silent confirmation",
        "  - Only show if issues detected",
        "Confirm ready for task execution:",
        "  - All required context loaded",
        "  - Position identified",
        "  - Inheritance resolved",
        "  - Confidence >= 0.8"
      ],

      "exitCondition": {
        "check": "Context delivered AND user provides task",
        "timeout": "None - wait for user input"
      },

      "output": {
        "contextReady": { "@type": "boolean" },
        "position": { "@ref": "ctx:NavigationStateActor.state" },
        "inheritanceChain": { "@type": "array" },
        "overridesApplied": { "@type": "array" },
        "confidence": { "@ref": "ctx:ContextConfidenceStateActor.overallConfidence" },
        "summary": { "@type": "string", "condition": "if debugMode" }
      },

      "readyIndicators": [
        "Agent knows current layer",
        "Agent knows current stage (if applicable)",
        "Agent knows applicable rules",
        "Agent knows what it inherits from",
        "Agent knows what it can override",
        "Confidence >= 0.8"
      ]
    }
  ]
}

{
  "@context": {
    "@vocab": "https://aalang.org/",
    "gab": "https://aalang.org/gab/",
    "ctx": "https://layer-stage.dev/context/",
    "ls": "https://layer-stage.dev/"
  },
  "@graph": [
    {
      "@id": "ctx:ContextLoadingStateActor",
      "@type": "gab:StateActor",
      "name": "Context Loading State Actor",
      "description": "Tracks which context files have been loaded in current session",
      "sessionConsistent": true,

      "state": {
        "loadedFiles": {
          "@type": "array",
          "description": "All context files loaded this session",
          "items": {
            "path": { "@type": "string", "description": "Full path to file" },
            "loadedAt": { "@type": "timestamp", "description": "When file was loaded" },
            "tokenCount": { "@type": "integer", "description": "Approximate token count" },
            "layer": { "@type": "integer", "description": "Layer number (-1, 0, 1, etc.)" },
            "canBeOverridden": { "@type": "boolean", "default": true }
          }
        },
        "claudeMdChain": {
          "@type": "array",
          "description": "Ordered list of CLAUDE.md files from root to cwd"
        },
        "rulesLoaded": { "@type": "boolean", "default": false },
        "protocolsLoaded": { "@type": "boolean", "default": false },
        "knowledgeLoaded": { "@type": "boolean", "default": false },
        "overrides": {
          "@type": "array",
          "description": "Explicit overrides detected during loading",
          "items": {
            "overridingFile": "string",
            "overriddenFile": "string",
            "what": "string",
            "reason": "string"
          }
        }
      },

      "methods": {
        "recordLoad": {
          "description": "Add file to loadedFiles with timestamp and layer",
          "params": ["path", "layer", "tokenCount"]
        },
        "isLoaded": {
          "description": "Check if file path already loaded",
          "params": ["path"],
          "returns": "boolean"
        },
        "getChainPosition": {
          "description": "Return current position in CLAUDE.md chain",
          "returns": { "current": "integer", "total": "integer" }
        },
        "recordOverride": {
          "description": "Record when a higher layer overrides a lower layer",
          "params": ["overridingFile", "overriddenFile", "what", "reason"]
        }
      }
    },

    {
      "@id": "ctx:ContextConfidenceStateActor",
      "@type": "gab:StateActor",
      "name": "Context Confidence State Actor",
      "description": "Tracks agent's confidence in current context understanding",
      "sessionConsistent": true,

      "state": {
        "layerIdentified": {
          "@type": "number",
          "min": 0,
          "max": 1,
          "description": "Confidence that current layer is correctly identified"
        },
        "stageIdentified": {
          "@type": "number",
          "min": 0,
          "max": 1,
          "description": "Confidence that current stage is correctly identified (or N/A)"
        },
        "rulesAwareness": {
          "@type": "number",
          "min": 0,
          "max": 1,
          "description": "Confidence that applicable rules are known"
        },
        "inheritanceResolved": {
          "@type": "number",
          "min": 0,
          "max": 1,
          "description": "Confidence that layer inheritance/overrides are correctly resolved"
        },
        "requiredContextLoaded": {
          "@type": "number",
          "min": 0,
          "max": 1,
          "description": "Confidence that all required context files are loaded"
        },
        "overallConfidence": {
          "@type": "number",
          "min": 0,
          "max": 1,
          "description": "Weighted average of all confidence scores"
        }
      },

      "calculation": {
        "overallConfidence": {
          "formula": "(layerIdentified * 0.25) + (stageIdentified * 0.15) + (rulesAwareness * 0.25) + (inheritanceResolved * 0.15) + (requiredContextLoaded * 0.20)",
          "weights": {
            "layerIdentified": 0.25,
            "stageIdentified": 0.15,
            "rulesAwareness": 0.25,
            "inheritanceResolved": 0.15,
            "requiredContextLoaded": 0.20
          }
        }
      },

      "thresholds": {
        "proceedToValidation": {
          "value": 0.6,
          "description": "Minimum confidence to proceed from loading to validation"
        },
        "proceedToPropagation": {
          "value": 0.8,
          "description": "Minimum confidence to proceed from validation to propagation"
        },
        "proceedToDelivery": {
          "value": 0.85,
          "description": "Minimum confidence to proceed from propagation to delivery"
        },
        "readyForWork": {
          "value": 0.8,
          "description": "Minimum confidence required before starting actual work"
        }
      }
    },

    {
      "@id": "ctx:NavigationStateActor",
      "@type": "gab:StateActor",
      "name": "Navigation State Actor",
      "description": "Tracks current position in layer-stage hierarchy",
      "sessionConsistent": true,

      "state": {
        "currentLayer": {
          "@type": "integer",
          "description": "Current layer number: -1 (research), 0 (universal), 1+ (projects)"
        },
        "currentStage": {
          "@type": "string",
          "pattern": "^(0[1-9]|1[01])$",
          "description": "Current stage: 01-11, or null if not in a stage"
        },
        "currentSubLayer": {
          "@type": "string",
          "description": "Current sub_layer name if nested (e.g., 'sub_layer_0_04_rules')"
        },
        "depth": {
          "@type": "integer",
          "description": "Nesting depth from filesystem root"
        },
        "layerStageDepth": {
          "@type": "integer",
          "description": "Nesting depth within layer-stage system (from 0_layer_universal)"
        },
        "path": {
          "@type": "string",
          "description": "Full path to current working directory"
        },
        "parent": {
          "@type": "string",
          "description": "Path to parent CLAUDE.md"
        },
        "children": {
          "@type": "array",
          "description": "Paths to child CLAUDE.md files (if any)"
        },
        "inheritanceChain": {
          "@type": "array",
          "description": "Ordered list of layers this position inherits from",
          "example": ["layer_0", "layer_1"]
        }
      },

      "methods": {
        "updatePosition": {
          "description": "Set current layer/stage/sub_layer based on cwd",
          "params": ["path"]
        },
        "getAncestors": {
          "description": "Return all parent CLAUDE.md paths in order",
          "returns": "array"
        },
        "getSiblings": {
          "description": "Return sibling directories at same level",
          "returns": "array"
        },
        "getInheritanceChain": {
          "description": "Return ordered list of layers being inherited from",
          "returns": "array"
        }
      }
    },

    {
      "@id": "ctx:DebugContextStateActor",
      "@type": "gab:StateActor",
      "name": "Debug Context State Actor",
      "description": "Controls visibility of context loading details for debugging",
      "sessionConsistent": true,

      "state": {
        "debugMode": {
          "@type": "boolean",
          "default": false,
          "description": "Master switch for debug output"
        },
        "verboseLoading": {
          "@type": "boolean",
          "default": false,
          "description": "Show each file as it loads"
        },
        "showConfidenceScores": {
          "@type": "boolean",
          "default": false,
          "description": "Display confidence scores during loading"
        },
        "showInheritance": {
          "@type": "boolean",
          "default": false,
          "description": "Show inheritance chain and overrides"
        },
        "logDecisions": {
          "@type": "boolean",
          "default": true,
          "description": "Log major decisions to context"
        }
      },

      "triggers": {
        "enableAll": "/context-debug on",
        "disableAll": "/context-debug off",
        "enableVerbose": "/context-debug verbose",
        "showStatus": "/context-status"
      },

      "output": {
        "format": "markdown",
        "sections": [
          "Files Loaded",
          "Current Position",
          "Inheritance Chain",
          "Overrides Applied",
          "Confidence Scores"
        ]
      }
    }
  ]
}

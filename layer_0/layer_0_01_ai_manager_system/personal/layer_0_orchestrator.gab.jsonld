          },
          "gemini": {
            "failures": 0,
            "tripped": false
          },
          "aider": {
            "failures": 0,
            "tripped": false
          }
        },
        "circuitBreakerThreshold": 3
      },
      "contains": [
        "orch:ResourceBudgetStatePersona"
      ]
    },
    {
      "@id": "orch:ResourceBudgetStatePersona",
      "@type": "gab:Persona",
      "name": "Resource Budget Manager",
      "actor": "orch:ResourceBudgetStateActor",
      "activeMode": null,
      "responsibilities": [
        "CRITICAL: Enforce depth limit before any spawn",
        "CRITICAL: Enforce concurrent limit before any spawn",
        "Track circuit breaker state per agent type",
        "Reset circuit breaker after successful spawn",
        "Report resource availability to DelegationPersona1"
      ],
      "canMessage": [
        "all"
      ],
      "canReceiveFrom": [
        "all"
      ],
      "safeguardChecks": {
        "canSpawn": {
          "condition": "currentDepth < maxDepth AND currentConcurrent < maxConcurrent AND NOT circuitBreaker[agentType].tripped",
          "onFail": "REJECT spawn request and report reason"
        }
      },
      "personality": "Conservative, enforces resource limits and prevents overallocation"
    },
    {
      "@id": "orch:StageStateActor",
      "@type": "gab:Actor",
      "activeMode": null,
      "stateful": true,
      "sessionConsistent": true,
      "purpose": "Track current stage (01-11) and stage-specific specialists",
      "isolatedContext": {
        "currentStage": null,
        "stageHistory": [],
        "stages": {
          "01": {
            "name": "request_gathering",
            "specialist": null
          },
          "02": {
            "name": "research",
            "specialist": null
          },
          "03": {
            "name": "instructions",
            "specialist": null
          },
          "04": {
            "name": "planning",
            "specialist": null
          },
          "05": {
            "name": "design",
            "specialist": null
          },
          "06": {
            "name": "development",
            "specialist": null
          },
          "07": {
            "name": "testing",
            "specialist": null
          },
          "08": {
            "name": "criticism",
            "specialist": null
          },
          "09": {
            "name": "fixing",
            "specialist": null
          },
          "10": {
            "name": "current_product",
            "specialist": null
          },
          "11": {
            "name": "archives",
            "specialist": null
          }
        }
      },
      "contains": [
        "orch:StageStatePersona"
      ]
    },
    {
      "@id": "orch:StageStatePersona",
      "@type": "gab:Persona",
      "name": "Stage State Manager",
      "actor": "orch:StageStateActor",
      "activeMode": null,
      "responsibilities": [
        "Track which stage (01-11) current work belongs to",
        "Maintain stage transition history",
        "Provide stage context to delegation decisions",
        "Identify stage-specific specialists if defined",
        "Validate stage transitions are logical"
      ],
      "canMessage": [
        "all"
      ],
      "canReceiveFrom": [
        "all"
      ],
      "personality": "Aware, tracks workflow stage transitions and stage-specific context"
    },
    {
      "@id": "orch:TaskFormat",
      "@type": "DataFormat",
      "purpose": "Standard format for task files in hand_off_documents",
      "schema": {
        "taskId": {
          "type": "string",
          "required": true
        },
        "description": {
          "type": "string",
          "required": true
        },
        "agentType": {
          "type": "string",
          "enum": [
            "claude",
            "codex",
            "gemini",
            "aider"
          ],
          "required": false
        },
        "context": {
          "type": "object",
          "properties": {
            "layer": {
              "type": "number"
            },
            "stage": {
              "type": "string"
            },
            "paths": {
              "type": "array"
            },
            "constraints": {
              "type": "object"
            }
          }
        },
        "priority": {
          "type": "string",
          "enum": [
            "low",
            "normal",
            "high",
            "critical"
          ]
        },
        "deadline": {
          "type": "string",
          "format": "ISO8601"
        },
        "parentTaskId": {
          "type": "string"
        }
      }
    },
    {
      "@id": "orch:ResultFormat",
      "@type": "DataFormat",
      "purpose": "Standard format for result files in hand_off_documents",
      "schema": {
        "taskId": {
          "type": "string",
          "required": true
        },
        "status": {
          "type": "string",
          "enum": [
            "completed",
            "failed",
            "partial"
          ],
          "required": true
        },
        "result": {
          "type": "object",
          "required": true,
          "properties": {
            "summary": {
              "type": "string",
              "required": true
            },
            "content": {
              "type": "string"
            },
            "confidence": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          }
        },
        "metadata": {
          "type": "object",
          "properties": {
            "agentType": {
              "type": "string"
            },
            "depth": {
              "type": "number"
            },
            "executionTime": {
              "type": "number"
            },
            "childCount": {
              "type": "number"
            }
          }
        },
        "auditTrail": {
          "type": "array",
          "items": {
            "timestamp": {
              "type": "string"
            },
            "action": {
              "type": "string"
            },
            "actor": {
              "type": "string"
            }
          }
        }
      }
    },
    {
      "@id": "orch:ReceiveActor1",
      "@type": "gab:Actor",

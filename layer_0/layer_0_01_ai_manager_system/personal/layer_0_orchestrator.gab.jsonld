    {
      "@id": "orch:ReceiveModeState",
      "@type": "gab:IsolatedState",
      "mode": "orch:ReceiveMode",
      "scope": "private to Receive Mode",
      "includes": [
        "Incoming task files parsed",
        "Task type classification",
        "Source identification (from_above vs from_below)",
        "Validation results"
      ],
      "readableBy": [
        "orch:ReceivePersona1",
        "orch:ReceivePersona2"
      ],
      "unreadableBy": [
        "orch:DelegationPersona1",
        "orch:DelegationPersona2",
        "orch:MonitoringPersona1",
        "orch:MonitoringPersona2",
        "orch:AggregationPersona1",
        "orch:AggregationPersona2",
        "orch:ReportPersona1",
        "orch:ReportPersona2"
      ]
    },

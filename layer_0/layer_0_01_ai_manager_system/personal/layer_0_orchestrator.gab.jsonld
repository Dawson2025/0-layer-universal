    {
      "@id": "orch:AggregationMode",
      "@type": "gab:Mode",
      "purpose": "Collect results from child agents and synthesize into unified output",
      "constraints": [
        "Collect result files from hand_off_documents/incoming/from_below/{child_id}/",
        "Parse and validate result JSON files",
        "Handle partial results from failed/timeout children",
        "Synthesize results based on aggregation strategy (merge, vote, summarize)",
        "Build unified result for reporting"
      ],
      "isolatedState": "orch:AggregationModeState",
      "contains": [
        "orch:AggregationPersona1",
        "orch:AggregationPersona2"
      ],
      "precedes": [
        "orch:ReportMode"
      ],
      "aggregationStrategies": {
        "merge": "Combine all results into single output",
        "vote": "Select result with highest confidence",
        "summarize": "Create summary from multiple perspectives",
        "hierarchical": "Build tree structure from results"
      }
    },
    {
      "@id": "orch:AggregationPersona1",
      "@type": "gab:Persona",

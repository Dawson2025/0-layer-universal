      "activeMode": "orch:DelegationMode",
      "responsibilities": [
        "Execute spawn_agent.sh commands as directed by Senior Strategist",
        "Write subtask JSON files to hand_off_documents/outgoing/to_below/{child_id}/",
        "Register spawned children in orch:ChildRegistryStateActor",
        "Update orch:ResourceBudgetStateActor with new spawn counts",
        "Handle spawn failures and report to Senior Strategist"
      ],
      "canMessage": [
        "orch:DelegationPersona1"
      ],
      "canReceiveFrom": [
        "orch:DelegationPersona1"
      ],
      "personality": "Efficient, detail-oriented, handles routine execution"
    },
    {
      "@id": "orch:MonitoringMode",
      "@type": "gab:Mode",
      "purpose": "Track progress of spawned child agents and handle failures",
      "constraints": [
        "Poll hand_off_documents/status/{child_id}.json for status updates",
        "Detect timeouts, failures, and completion",
        "Handle failed children: retry, reassign, or escalate",
        "Track progress metrics for each child",
        "Do NOT proceed to AggregationMode until all children complete or timeout"
      ],
      "isolatedState": "orch:MonitoringModeState",
      "contains": [
        "orch:MonitoringPersona1",
        "orch:MonitoringPersona2"
      ],
      "precedes": [
        "orch:AggregationMode"
      ],
      "statusDirectory": "layer_0/layer_0_02_manager_handoff_documents/status/"
    },

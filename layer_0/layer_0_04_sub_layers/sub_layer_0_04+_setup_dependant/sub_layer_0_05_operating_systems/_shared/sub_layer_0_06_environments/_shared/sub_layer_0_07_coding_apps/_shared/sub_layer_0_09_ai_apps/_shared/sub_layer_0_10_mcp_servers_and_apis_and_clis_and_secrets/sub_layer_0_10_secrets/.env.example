# ===========================================
# API Keys for MCP Servers & AI Apps
# ===========================================
# DO NOT COMMIT actual values - copy this to .env and fill in
# Get actual values from Google Secret Manager or ~/.env
#
# To retrieve from Secret Manager:
#   gcloud secrets versions access latest --secret=SECRET_NAME
# ===========================================

# Canvas LMS API (BYU-Idaho)
# Generate at: Canvas > Account > Settings > Approved Integrations
CANVAS_API_KEY=your_canvas_api_key_here
CANVAS_BASE_URL=https://byui.instructure.com

# Perplexity API
# Generate at: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=pplx-your_perplexity_api_key_here

# ===========================================
# Google Cloud (for Secret Manager access)
# ===========================================
# GCP_PROJECT_ID=assignment-time

# ===========================================
# Usage
# ===========================================
# Option 1: Source directly
#   source .env && echo $CANVAS_API_KEY
#
# Option 2: Use with scripts
#   export $(cat .env | xargs) && your_script.sh
#
# Option 3: Symlink to ~/.env
#   ln -sf ~/.env .env
